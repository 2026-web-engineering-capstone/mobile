{
  "name": "gyoum-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "EXPO_PACKAGER_PROXY_URL=http://localhost:8081 expo start --dev-client --localhost",
    "start:clear": "EXPO_PACKAGER_PROXY_URL=http://localhost:8081 expo start --dev-client --localhost --clear",
    "start:tunnel": "expo start --dev-client --tunnel",
    "android": "ANDROID_HOME=\"$HOME/Library/Android/sdk\" ANDROID_SDK_ROOT=\"$HOME/Library/Android/sdk\" PATH=\"$HOME/Library/Android/sdk/emulator:$HOME/Library/Android/sdk/platform-tools:$PATH\" expo run:android",
    "ios": "EXPO_PACKAGER_PROXY_URL=http://localhost:8081 expo run:ios --no-bundler",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mj-studio/react-native-naver-map": "^2.7.0",
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@tanstack/react-query": "^5.95.2",
    "expo": "~55.0.9",
    "expo-build-properties": "^55.0.10",
    "expo-constants": "^55.0.9",
    "expo-dev-client": "~55.0.19",
    "expo-device": "^55.0.15",
    "expo-linking": "^55.0.9",
    "expo-location": "~55.1.2",
    "expo-notifications": "^55.0.19",
    "expo-router": "~55.0.8",
    "expo-status-bar": "~55.0.4",
    "heroui-native": "^1.0.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.1",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.7.2",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4",
    "uniwind": "^1.6.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.2.0",
    "typescript": "~5.9.3"
  },
  "packageManager": "yarn@4.13.0"
}
